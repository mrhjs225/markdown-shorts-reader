{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "types": ["node", "vscode", "vitest/globals"],
    "noEmit": true
  },
  "include": ["src", "test", "esbuild.js", "eslint.config.mjs"]
}
